# Frontend (static) — all optional.

# Override the serverless send endpoint (defaults to /api/send-test).
# VITE_SEND_ENDPOINT=/api/send-test

# --- Serverless function env (api/send-test.ts) ---
# Set these in your hosting provider (e.g. Vercel project settings), NOT here.
# Without RESEND_API_KEY the send endpoint is a no-op.
# RESEND_API_KEY=
# MAIL_FROM=onboarding@resend.dev
