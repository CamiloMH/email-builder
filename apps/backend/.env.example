# Server
PORT=3005
NODE_ENV=development

# Database (MariaDB / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=email_templates
# Set to "true" only for local development; use migrations in production.
DB_SYNCHRONIZE=true

# Rate limiting (global)
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
# Stricter limit for the expensive render endpoint
RENDER_THROTTLE_LIMIT=20

# CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# Email delivery (Resend) — optional. Without RESEND_API_KEY, test sends no-op.
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
